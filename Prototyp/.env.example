# ── Medi-Interpret — Beispiel-Konfiguration ─────────────────────────────────
# Kopieren nach .env und bei Bedarf anpassen. Die Defaults funktionieren lokal.

# App
APP_NAME=Medi-Interpret
LOG_LEVEL=INFO
DEBUG=false

# Ollama (lokales LLM + Embeddings)
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=llama3.2
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_NUM_CTX=4096

# Weaviate (lokale Vektor-Datenbank)
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_CLASS_NAME=RagChunk

# Ingestion / Chunking
DEFAULT_LOADER=auto
CHUNK_STRATEGY=recursive
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Datenschutz: PII vor dem Einbetten entfernen (DSGVO Art. 9)
DEIDENTIFY_ENABLED=true

# Retrieval
TOP_K=5
SIMILARITY_THRESHOLD=0.70

# Marker (optionaler, hochwertiger PDF-Loader; lädt beim ersten Lauf ~1 GB)
MARKER_ENABLED=true
