# ── Ollama ───────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
CHAT_MODEL=llama3.2          # or: mistral / phi3 / gemma2 / qwen2.5
EMBEDDING_MODEL=nomic-embed-text

# ── Weaviate (local Docker) ───────────────────────────────────────────────
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_CLASS_NAME=RagChunk

# ── Ingestion ─────────────────────────────────────────────────────────────
DEFAULT_LOADER=auto           # auto | unstructured | marker | pymupdf
CHUNK_STRATEGY=recursive      # recursive | semantic | fixed
CHUNK_SIZE=512
CHUNK_OVERLAP=64
UPLOAD_DIR=uploads

# ── Retrieval ─────────────────────────────────────────────────────────────
TOP_K=5
SIMILARITY_THRESHOLD=0.70

# ── Marker ────────────────────────────────────────────────────────────────
MARKER_ENABLED=true
# MARKER_MAX_PAGES=50         # uncomment to cap page count

# ── App ───────────────────────────────────────────────────────────────────
DEBUG=false
LOG_LEVEL=INFO
