# Zeilenenden normalisieren — verhindert die LF/CRLF-Warnungen unter Windows.
# Git speichert Textdateien intern mit LF und checkt sie passend zum OS aus.
* text=auto

# Eindeutig textbasierte Dateien
*.py    text
*.md    text
*.txt   text
*.html  text
*.css   text
*.js    text
*.yml   text
*.yaml  text
*.json  text
*.env   text
*.csv   text

# Binärdateien nicht anfassen
*.pdf   binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.webp  binary
*.tiff  binary
